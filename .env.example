# =============================================================
# Ambassador Global Academy - School Management System
# Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local to version control.
# =============================================================

# -------------------------------------------------------------
# DATABASE (Neon PostgreSQL)
# -------------------------------------------------------------
# Pooled connection — used at runtime by the app (PrismaClient)
# Use the Neon "pooled" connection string (hostname contains -pooler)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection — used by Prisma CLI (migrations, db push, db seed)
# Use the Neon "direct" connection string (no -pooler in hostname)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# -------------------------------------------------------------
# Auth.js (next-auth v5)
# -------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# For local development:
AUTH_URL="http://localhost:3000"

# For Vercel production, set AUTH_URL to your deployment URL, e.g.:
# AUTH_URL="https://your-app.vercel.app"
# Or leave it unset — Auth.js v5 auto-detects VERCEL_URL on Vercel.

# -------------------------------------------------------------
# Email / SMTP (configure when email provider is selected)
# -------------------------------------------------------------
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM=""
