# =============================================================
# Ambassador Global Academy - School Management System
# Environment Variables Template
# Copy to .env.local for local development.
# NEVER commit .env or .env.local to version control.
# =============================================================

# -------------------------------------------------------------
# DATABASE (Neon PostgreSQL)
# -------------------------------------------------------------
# Pooled — runtime (PrismaClient). Use Neon's "pooled" URL (-pooler).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct — Prisma CLI only (migrations, db push, db seed). Use Neon's "direct" URL (no -pooler).
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# -------------------------------------------------------------
# Auth.js v5 (next-auth)
# -------------------------------------------------------------
# Required. Generate with: openssl rand -base64 32
AUTH_SECRET="your-generated-secret-here"

# Set for local dev only. In production on Vercel, remove this
# or set to your production URL. Auth.js auto-detects on Vercel.
AUTH_URL="http://localhost:3000"

# Required on Vercel — lets Auth.js work behind the reverse proxy.
AUTH_TRUST_HOST=true
